rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper Functions ----------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    // ---------- Users Collection ----------
    
    match /users/{userId} {
      // Anyone signed in can read (needed for profiles/matching)
      allow read: if isSignedIn();
      // Only the user themselves can create or update their document
      allow create, update: if isOwner(userId);
      // Only admin can delete users (or adjust as needed)
      allow delete: if false; 
    }

    // ---------- Medicines Collection ----------
    
    match /medicines/{medicineId} {
      // Anyone signed in can view active medicines 
      allow read: if isSignedIn();
      
      // Ensure expiryDate is at least 60 days (approx 5.184e+9 ms) from request time
      allow create, update: if isSignedIn() &&
        // Ensure pharmacist is creating it for themselves
        request.resource.data.pharmacyId == request.auth.uid &&
        // Check 60 days (60 * 24 * 60 * 60 seconds) duration
        (request.resource.data.expiryDate > (request.time + duration.value(60, 'd')));
        
      allow delete: if isSignedIn() && resource.data.pharmacyId == request.auth.uid;
    }

    // ---------- Donations & Requests ----------
    
    match /donations/{donationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.donorId == request.auth.uid;
      allow update: if isSignedIn() && (
        // Owner can update everything
        resource.data.donorId == request.auth.uid ||
        // NGO can reserve a donation
        (request.resource.data.status == 'reserved' && 
         request.resource.data.reservedByNgoId == request.auth.uid &&
         resource.data.status == 'available') ||
        // NGO can revert their own reservation
        (request.resource.data.status == 'available' && 
         resource.data.reservedByNgoId == request.auth.uid)
      );
      allow delete: if isSignedIn() && resource.data.donorId == request.auth.uid;
    }

    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ngoId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ngoId == request.auth.uid;
    }

    match /matches/{matchId} {
      // Only donor or ngo involved can read/update the match, plus admins
      allow read, update: if isSignedIn() && 
        (request.auth.uid == resource.data.donorId || request.auth.uid == resource.data.ngoId);
      allow create: if isSignedIn(); // Add backend function constraints ideally
      allow delete: if false;
    }

    // ---------- Notifications Collection ----------
    
    match /notifications/{userId} {
      allow read: if isOwner(userId);
      
      match /items/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        // Anyone can create a notification for another user
        allow create: if isSignedIn();
      }
    }

    // ---------- Chat Rooms Collection ----------
    
    match /chatRooms/{chatRoomId} {
      // Only the listed donor and receiver can access the chat room
      allow read, update: if isSignedIn() &&
        (request.auth.uid == resource.data.donorId || request.auth.uid == resource.data.receiverId);
        
      allow create: if isSignedIn() &&
        (request.auth.uid == request.resource.data.donorId || request.auth.uid == request.resource.data.receiverId);
        
      allow delete: if false;
      
      // Messages subcollection
      match /messages/{messageId} {
        // Read parent document to verify participants
        allow read, create: if isSignedIn() &&
          (request.auth.uid == get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.donorId || 
           request.auth.uid == get(/databases/$(database)/documents/chatRooms/$(chatRoomId)).data.receiverId) &&
          // Ensuring senderId matches auth user upon creation
          (request.method == 'read' || request.resource.data.senderId == request.auth.uid);
          
        allow update, delete: if false; // Immutable messages
      }
    }
    
    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
